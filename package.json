{
  "name": "papertrail",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "버전 관리형 전자문서 생성 및 증적 플랫폼 (공용 문서 렌더링 SaaS)",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!**/node_modules/**\"",
    "typecheck": "pnpm -r --if-present typecheck",
    "check": "pnpm run format:check && pnpm run lint && pnpm run lint:md && pnpm run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "markdownlint-cli2": "^0.23.1",
    "prettier": "^3.9.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
