{
  "name": "@papertrail/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "PaperTrail 영속성 계층 (Drizzle ORM 스키마 + PostgreSQL 클라이언트 + 마이그레이션)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "typecheck": "tsgo --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@papertrail/contracts": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
