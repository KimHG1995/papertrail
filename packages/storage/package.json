{
  "name": "@papertrail/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "PaperTrail 오브젝트 스토리지 클라이언트 (S3/MinIO 어댑터 + Signed URL + 키 레이아웃)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3"
  }
}
