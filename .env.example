# PaperTrail 로컬 개발 환경 변수 예시.
# 복사해서 사용:  cp .env.example .env
# docker-compose.yml 과 애플리케이션(게이트웨이/워커)이 공유한다.

# --- PostgreSQL (상태, 증적, 멱등성) ---
POSTGRES_USER=papertrail
POSTGRES_PASSWORD=papertrail
POSTGRES_DB=papertrail
POSTGRES_PORT=5432
DATABASE_URL=postgres://papertrail:papertrail@localhost:5432/papertrail

# --- Redis (BullMQ 큐/DLQ) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO / S3 (PDF, 템플릿 asset, 원본 CSV) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=papertrail
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- ClickHouse (렌더 이벤트, 통계 집계) ---
# 사용자/비밀번호/papermake DB 는 Papermake 요구사항에 맞춰 둔다.
# 우리 분석은 papertrail DB(init 스크립트로 생성)를 사용한다.
CLICKHOUSE_DB=papermake
CLICKHOUSE_USER=papermake
CLICKHOUSE_PASSWORD=papermake123
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9009
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=papertrail

# --- Papermake (렌더 엔진, profile: papermake) ---
PAPERMAKE_PORT=3100
PAPERMAKE_URL=http://localhost:3100
# 렌더 워커의 Papermake 드라이버: fake(로컬 기본, Rust 없이 결정적 가짜 렌더) | http(실제 Papermake)
PAPERMAKE_DRIVER=fake

# --- 게이트웨이 ---
PORT=3000
